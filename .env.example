# Financial Data Provider — environment configuration
# Copy this file to .env and fill in real values. Never commit .env.

# ── Provider selection ───────────────────────────────────────────────────────
PROVIDER=cal

# ── CAL credentials ──────────────────────────────────────────────────────────
CAL_USERNAME=your_cal_username_here
CAL_PASSWORD=your_cal_password_here
# Optional: identifies this account in session files and export filenames.
# Useful if you later run multiple accounts. Defaults to 'default'.
# CAL_ACCOUNT_ID=my_visa

# ── Future provider: MAX (uncomment when adding) ──────────────────────────────
# MAX_USERNAME=your_max_username_here
# MAX_PASSWORD=your_max_password_here
# MAX_ACCOUNT_ID=default

# ── Multi-account (source accounts) ───────────────────────────────────────────
# Run several source accounts (per provider) with `npm run fetch:all`.
# Each account keeps isolated session/seen/checkpoint state and export metadata.
# If neither of the options below is set, the single default CAL account above is
# used (fully backward compatible).
#
# Option A — a JSON file (path below; copy accounts.config.example.json):
# ACCOUNTS_CONFIG=accounts.config.json
#
# Option B — inline JSON array (credentials referenced by env-var NAME, not value):
# SOURCE_ACCOUNTS=[{"provider":"cal","providerAccountId":"oz_cal","displayName":"Oz CAL","credentials":{"usernameEnv":"OZ_CAL_USERNAME","passwordEnv":"OZ_CAL_PASSWORD"}}]
#
# Then define the referenced credential env vars, e.g.:
# OZ_CAL_USERNAME=...
# OZ_CAL_PASSWORD=...
# WIFE_CAL_USERNAME=...
# WIFE_CAL_PASSWORD=...

# ── Browser settings ─────────────────────────────────────────────────────────
# HEADLESS=true     (set to false to watch the browser during debugging)
# SLOW_MO=0         (ms between Playwright actions, useful for debugging)

# ── Fetch settings ───────────────────────────────────────────────────────────
# DAYS_BACK=4

# ── Runtime state locations ──────────────────────────────────────────────────
# Local state lives under runtime/ by default. Override individually if needed.
# Legacy .seen/.sessions/.checkpoints/exports are auto-migrated on first run.
# EXPORT_PATH=runtime/exports
# SEEN_DIR=runtime/seen
# CHECKPOINT_DIR=runtime/checkpoints
# Directory for per-provider/account Playwright session state files (auth cookies).
# Keep this out of version control (.gitignore excludes runtime/).
# SESSION_DIR=runtime/sessions

# ── HTTP API settings ────────────────────────────────────────────────────────
# API_PORT=3000
# API_KEY=           (if set, requests must include X-API-Key header with this value)
#                    (leave empty for open localhost access — the default)

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info    (debug | info | warn | error)
# DEBUG=false       (setting true overrides LOG_LEVEL to debug)

# ── CLI account override ──────────────────────────────────────────────────────
# ACCOUNT_ID=       (same as --account CLI flag — overrides the provider's accountId)
