# Financial Data Bridge — non-secret developer/runtime configuration (optional)
#
# Normal users do NOT need this file. Run the desktop app (`npm run desktop`) and
# enter credentials in the UI — they are stored encrypted by the OS (Electron
# safeStorage), never in this file.
#
# This file holds ONLY non-secret developer/runtime tweaks. Do NOT put usernames
# or passwords here. (The advanced developer-only CLI fallback and how it reads
# credentials is documented in docs/RUNBOOK.md → "Advanced developer fallback".)
#
# Copy to `.env` (gitignored) if you need to override a default below.

# ── Provider selection ───────────────────────────────────────────────────────
PROVIDER=cal

# ── Fetch settings (optional) ────────────────────────────────────────────────
# DAYS_BACK=4

# ── Browser settings (optional, for debugging the scraper) ───────────────────
# HEADLESS=true     (set to false to watch the browser)
# SLOW_MO=0         (ms between Playwright actions)

# ── Runtime state locations (optional overrides) ─────────────────────────────
# Local state defaults to runtime/ (gitignored). Override individually if needed.
# EXPORT_PATH=runtime/exports
# SEEN_DIR=runtime/seen
# CHECKPOINT_DIR=runtime/checkpoints
# SESSION_DIR=runtime/sessions

# ── Multi-account config file path (optional; non-secret) ────────────────────
# Accounts are normally managed in the desktop UI (written to accounts.config.json).
# This only points at that file; it contains NO secrets.
# ACCOUNTS_CONFIG=accounts.config.json

# ── Logging (optional) ───────────────────────────────────────────────────────
# LOG_LEVEL=info    (debug | info | warn | error)
# DEBUG=false       (true overrides LOG_LEVEL to debug)
