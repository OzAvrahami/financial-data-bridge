# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Claude Code local state ──────────────────────────────────────────────────
.claude/

# ── Environment & credentials ────────────────────────────────────────────────
# Real secrets live in .env / .env.local — never commit them.
# .env.example is the safe, committed template (placeholders only).
.env
.env.*
!.env.example
# Local multi-account config (references credential keys / env-var names — no
# secrets). accounts.config.example.json is the safe, committed template.
accounts.config.json

# Encrypted credential stores (Electron safeStorage). These normally live in the
# OS userData dir (outside the repo), but ignore them defensively everywhere.
*.enc.json
credentials.enc.json

# ── Playwright / browser / session artifacts ─────────────────────────────────
# Session state files contain auth cookies — never commit these.
.sessions/
.storage/
storageState*.json
test-results/
playwright-report/
playwright/.cache/
*.png
*.webm

# ── Runtime state (generated locally) ────────────────────────────────────────
# Everything under runtime/ is local state (seen dedup fingerprints, sessions,
# checkpoints, and generated transaction exports — all private). The folder is
# kept via runtime/.gitkeep; its contents are ignored.
runtime/*
!runtime/.gitkeep

# Legacy pre-restructure locations — keep ignored if they still exist locally.
.seen/
.sessions/
.checkpoints/
.data/
exports/

# ── Financial / private generated data ───────────────────────────────────────
# (Exports now live under runtime/exports/ — covered by the runtime/ rule above.)

# ── Logs & debug output ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Build / coverage artifacts ───────────────────────────────────────────────
dist/
build/
coverage/
.nyc_output/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
