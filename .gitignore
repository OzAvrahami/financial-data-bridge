# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Claude Code local state ──────────────────────────────────────────────────
.claude/

# ── Environment & credentials ────────────────────────────────────────────────
# Normal desktop use needs no .env. If present (developer machine), it may hold
# non-secret overrides only — never commit it.
.env
.env.*
# Local multi-account config (provider/account metadata + a credentialKey
# reference — no secrets). accounts.config.example.json is the committed template.
accounts.config.json

# Encrypted credential stores (Electron safeStorage). These normally live in the
# OS userData dir (outside the repo), but ignore them defensively everywhere.
*.enc.json
credentials.enc.json

# ── Playwright / browser / session artifacts ─────────────────────────────────
# Session state files contain auth cookies — never commit these. Real session
# state lives under runtime/sessions/ (ignored via the runtime/ rule below).
.storage/
storageState*.json
test-results/
playwright-report/
playwright/.cache/
*.png
*.webm

# ── Runtime state (generated locally) ────────────────────────────────────────
# Everything under runtime/ is local state (seen dedup fingerprints, sessions,
# checkpoints, and generated transaction exports — all private). The folder is
# kept via runtime/.gitkeep; its contents are ignored.
runtime/*
!runtime/.gitkeep

# ── Logs & debug output ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Build / coverage artifacts ───────────────────────────────────────────────
dist/
build/
coverage/
.nyc_output/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
