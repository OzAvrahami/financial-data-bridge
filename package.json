{
  "name": "financial-data-provider",
  "version": "3.0.0",
  "description": "Automated financial data provider service — fetches transactions from credit card and bank websites. Supports CAL; designed for multi-provider extension.",
  "main": "apps/cli/index.js",
  "type": "module",
  "scripts": {
    "start": "node packages/bridge-core/src/api/index.js",
    "fetch": "node apps/cli/index.js",
    "fetch:all": "node apps/cli/index.js --all-accounts",
    "desktop": "electron apps/desktop/main.cjs",
    "export:finance": "node scripts/exportToFinance.js",
    "test": "node tests/runner.js tests",
    "test:unit": "node tests/runner.js tests/unit",
    "test:integration": "node tests/runner.js tests/integration"
  },
  "keywords": [
    "playwright",
    "automation",
    "finance",
    "credit-card",
    "transactions",
    "cal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.56.1",
    "dotenv": "^16.4.5",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "^33.4.11"
  }
}
