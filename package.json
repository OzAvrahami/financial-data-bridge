{
  "name": "financial-data-bridge",
  "version": "3.0.1",
  "description": "Desktop app that fetches, deduplicates, and exports credit-card/bank transactions (CAL today; multi-provider by design). Electron UI on top of the bridge-core engine.",
  "main": "apps/desktop/main.cjs",
  "type": "module",
  "scripts": {
    "desktop": "electron apps/desktop/main.cjs",
    "test": "node tests/runner.js tests",
    "test:unit": "node tests/runner.js tests/unit",
    "test:integration": "node tests/runner.js tests/integration",
    "bundle:browsers": "node scripts/bundle-browsers.mjs",
    "pack:desktop": "npm run bundle:browsers && electron-builder --dir",
    "dist:desktop": "npm run bundle:browsers && electron-builder",
    "dist:desktop:win": "npm run bundle:browsers && electron-builder --win nsis portable"
  },
  "keywords": [
    "electron",
    "desktop",
    "playwright",
    "finance",
    "credit-card",
    "transactions",
    "cal"
  ],
  "private": true,
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.56.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
